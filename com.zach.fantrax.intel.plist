<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zach.fantrax.intel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd /Users/zach/Projects/fantrax-daily-audit &amp;&amp; ./.venv/bin/python league_intel.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/zach/Projects/fantrax-daily-audit</string>

    <!-- Sundays at 7am local. Weekday: 0=Sun, 1=Mon, ... -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>0</integer>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/zach/Projects/fantrax-daily-audit/.data/logs/launchd-intel-stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/zach/Projects/fantrax-daily-audit/.data/logs/launchd-intel-stderr.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
