# Fantrax credentials (required for first-run cookie capture)
FANTRAX_USER=your-fantrax-email@example.com
FANTRAX_PASS=your-fantrax-password

# League and team
FANTRAX_LEAGUE_ID=lydahdo6mhcvnob7
FANTRAX_TEAM_ID=tuumpjsjmhcvnobp

# Sandlot web app (Railway)
DATABASE_URL=postgresql://user:password@host:5432/railway
SANDLOT_REFRESH_TOKEN=replace-with-a-private-token
SANDLOT_KEEP_SNAPSHOTS=30
SANDLOT_PROFILE_WARM_ENABLED=0
SANDLOT_PROFILE_WARM_LIMIT=12
SANDLOT_PROFILE_WARM_PARALLELISM=3
SANDLOT_PROFILE_WARM_TAKES=0
SANDLOT_WAIVER_AI_WARM_ENABLED=0
# Local-only owner confirmation bridge. Never deploy or expose this plaintext.
SANDLOT_OWNER_ACTION_TOKEN=
SANDLOT_BROWSER_ORIGIN=https://web-production-90664.up.railway.app
# Optional fallback if you do not seed fantrax_sessions from local cookies.
# FANTRAX_COOKIES_JSON=[]

# Email delivery (Gmail)
# Anthropic API — required for grounded research + synthesis
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# OpenRouter — Skipper chat (Kimi primary, DeepSeek fallback)
# Create at: https://openrouter.ai/keys
OPENROUTER_API_KEY=replace-with-openrouter-api-key

# Email delivery (optional — only used if you keep the email path)
# Web app on Railway is the recommended path; if you skip email, leave these blank.
EMAIL_FROM=your-gmail@gmail.com
EMAIL_TO=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional: full path to claude CLI if `claude` isn't on PATH for launchd
# CLAUDE_CMD=/usr/local/bin/claude

# Optional: set to 1 to force selenium to run with a visible browser window
# (useful for debugging login flow). Defaults to headless after first run.
# FANTRAX_HEADFUL=0
